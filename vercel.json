{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "apps/marketing/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [{ "src": "/api/(.*)", "dest": "apps/api/src/main.ts" }],
  "env": {
    "NODE_ENV": "production"
  }
}
